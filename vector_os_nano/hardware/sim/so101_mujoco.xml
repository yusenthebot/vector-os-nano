<!--
  SO-101 tabletop manipulation scene for MuJoCo.
  Robot model compiled from so101.urdf with real STL meshes.
  Includes: robot on table, graspable objects, position-control actuators, cameras.
-->
<mujoco model="so101_tabletop">

  <compiler angle="radian" meshdir="../urdf/meshes/" autolimits="true"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast">
    <flag contact="enable"/>
  </option>

  <default>
    <joint damping="0.5" armature="0.05"/>
    <geom condim="4" friction="1 0.005 0.0001"
          solimp="0.95 0.99 0.001" solref="0.02 1"/>
    <default class="robot">
      <!-- Robot arm mesh geoms: no collision at all (visual only for physics).
           Only the finger geoms (fixed_jaw, moving_jaw) have real collision. -->
      <geom contype="0" conaffinity="0"/>
    </default>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.9 0.9 0.9" rgb2="0.7 0.7 0.7"/>
    <material name="grid" texture="grid" texrepeat="8 8"/>

    <!-- SO-101 STL meshes -->
    <mesh name="base_motor_holder_so101_v1" file="base_motor_holder_so101_v1.stl"/>
    <mesh name="base_so101_v2" file="base_so101_v2.stl"/>
    <mesh name="sts3215_03a_v1" file="sts3215_03a_v1.stl"/>
    <mesh name="waveshare_mounting_plate_so101_v2" file="waveshare_mounting_plate_so101_v2.stl"/>
    <mesh name="motor_holder_so101_base_v1" file="motor_holder_so101_base_v1.stl"/>
    <mesh name="rotation_pitch_so101_v1" file="rotation_pitch_so101_v1.stl"/>
    <mesh name="upper_arm_so101_v1" file="upper_arm_so101_v1.stl"/>
    <mesh name="under_arm_so101_v1" file="under_arm_so101_v1.stl"/>
    <mesh name="motor_holder_so101_wrist_v1" file="motor_holder_so101_wrist_v1.stl"/>
    <mesh name="sts3215_03a_no_horn_v1" file="sts3215_03a_no_horn_v1.stl"/>
    <mesh name="wrist_roll_pitch_so101_v2" file="wrist_roll_pitch_so101_v2.stl"/>
    <mesh name="wrist_roll_follower_so101_v1" file="wrist_roll_follower_so101_v1.stl"/>
    <mesh name="moving_jaw_so101_v1" file="moving_jaw_so101_v1.stl"/>

    <!-- Object meshes — copied to urdf/meshes/ so meshdir resolves them -->
    <mesh name="banana_mesh" file="banana.stl"/>
    <mesh name="mug_mesh" file="mug.stl"/>
    <mesh name="bottle_mesh" file="bottle.stl"/>
    <mesh name="screwdriver_mesh" file="screwdriver.stl"/>
    <mesh name="duck_mesh" file="duck.stl" scale="0.8 0.8 0.8"/>
    <mesh name="lego_mesh" file="lego.stl"/>
  </asset>

  <worldbody>
    <!-- Lighting -->
    <light pos="0.3 0 0.8" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light pos="0 0.3 0.6" dir="0 -0.3 -1" diffuse="0.4 0.4 0.4"/>

    <!-- Ground -->
    <geom name="floor" type="plane" size="1 1 0.01" material="grid" condim="3"/>

    <!-- Table (static, workspace surface at z=0.02) -->
    <body name="table" pos="0.20 0 0">
      <geom name="tabletop" type="box" size="0.30 0.25 0.01" pos="0 0 0.01"
            rgba="0.72 0.62 0.45 1" mass="100"/>
    </body>

    <!-- Cameras -->
    <camera name="overhead" pos="0.20 0 0.55" quat="1 0 0 0" fovy="60"/>
    <camera name="front"    pos="0.20 0.50 0.25" xyaxes="1 0 0 0 -0.3 1" fovy="50"/>
    <camera name="side"     pos="-0.30 0 0.25"   xyaxes="0 -1 0 0 0 1" fovy="50"/>

    <!-- ============================================================
         SO-101 Robot (real STL meshes, compiled from so101.urdf)
         Mounted on table surface at z=0.02.
         ============================================================ -->
    <body name="base_link" pos="0 0 0.02">
      <!-- base_link visual geoms -->
      <geom pos="-0.00636471 -9.94414e-05 -0.0024" quat="0.499998 0.5 0.500002 0.5" type="mesh" class="robot" rgba="1 0.82 0.12 1" mesh="base_motor_holder_so101_v1" mass="0.05"/>
      <geom pos="-0.00636471 -8.97657e-09 -0.0024" quat="0.499998 0.5 0.500002 0.5" type="mesh" class="robot" rgba="1 0.82 0.12 1" mesh="base_so101_v2" mass="0.05"/>
      <geom name="base_servo" pos="0.0263353 -8.97657e-09 0.0437" quat="1 0 0 0" type="mesh" class="robot" rgba="0.1 0.1 0.1 1" mesh="sts3215_03a_v1" mass="0.03"/>
      <geom pos="-0.0309827 -0.000199441 0.0474" quat="0.499998 0.5 0.500002 0.5" type="mesh" class="robot" rgba="1 0.82 0.12 1" mesh="waveshare_mounting_plate_so101_v2" mass="0.02"/>

      <body name="shoulder_link" pos="0.0388353 -8.97657e-09 0.0624" quat="0 0 -1 0">
        <inertial pos="-0.0307604 -1.66727e-05 -0.0252713" mass="0.100" diaginertia="8.4e-05 8.1e-05 2.4e-05"/>
        <joint name="shoulder_pan" axis="0 0 1" range="-1.92 1.92"/>
        <geom pos="-0.0303992 0.000422241 -0.0417" quat="0.499998 0.5 0.5 -0.500002" type="mesh" class="robot" rgba="0.1 0.1 0.1 1" mesh="sts3215_03a_v1"/>
        <geom pos="-0.0675992 -0.000177759 0.0158499" quat="0.499998 0.5 -0.5 0.500002" type="mesh" class="robot" rgba="1 0.82 0.12 1" mesh="motor_holder_so101_base_v1"/>
        <geom pos="0.0122008 2.22413e-05 0.0464" quat="0.707105 -0.707108 0 0" type="mesh" class="robot" rgba="1 0.82 0.12 1" mesh="rotation_pitch_so101_v1"/>

        <body name="upper_arm_link" pos="-0.0303992 -0.0182778 -0.0542" quat="0.5 -0.5 -0.5 -0.5">
          <inertial pos="-0.0898471 -0.00838224 0.0184089" quat="0.5 0.5 0.5 0.5" mass="0.103" diaginertia="0.000147 0.000142 4.1e-05"/>
          <joint name="shoulder_lift" axis="0 0 1" range="-1.75 1.75"/>
          <geom pos="-0.11257 -0.0155 0.0187" quat="0 -0.707105 0.707108 0" type="mesh" class="robot" rgba="0.1 0.1 0.1 1" mesh="sts3215_03a_v1"/>
          <geom pos="-0.065085 0.012 0.0182" quat="0 1 0 0" type="mesh" class="robot" rgba="1 0.82 0.12 1" mesh="upper_arm_so101_v1"/>

          <body name="lower_arm_link" pos="-0.11257 -0.028 0" quat="0.707107 0 0 0.707107">
            <inertial pos="-0.0980701 0.00324376 0.0182831" quat="0.5 0.5 0.5 0.5" mass="0.104" diaginertia="0.00016 0.000145 2.9e-05"/>
            <joint name="elbow_flex" axis="0 0 1" range="-1.69 1.69"/>
            <geom pos="-0.0648499 -0.032 0.0182" quat="0 1 0 0" type="mesh" class="robot" rgba="1 0.82 0.12 1" mesh="under_arm_so101_v1"/>
            <geom pos="-0.0648499 -0.032 0.018" quat="0 -1 0 0" type="mesh" class="robot" rgba="1 0.82 0.12 1" mesh="motor_holder_so101_wrist_v1"/>
            <geom pos="-0.1224 0.0052 0.0187" quat="0 0 1 0" type="mesh" class="robot" rgba="0.1 0.1 0.1 1" mesh="sts3215_03a_v1"/>

            <body name="wrist_link" pos="-0.1349 0.0052 0" quat="0.707107 0 0 -0.707107">
              <inertial pos="-0.000103312 -0.0386143 0.0281156" mass="0.079" diaginertia="3.7e-05 2.5e-05 2.1e-05"/>
              <joint name="wrist_flex" axis="0 0 1" range="-1.66 1.66"/>
              <geom pos="0 -0.0424 0.0306" quat="0.499998 0.5 0.5 -0.500002" type="mesh" class="robot" rgba="0.1 0.1 0.1 1" mesh="sts3215_03a_no_horn_v1"/>
              <geom pos="0 -0.028 0.0181" quat="0.499998 -0.5 -0.5 -0.500002" type="mesh" class="robot" rgba="1 0.82 0.12 1" mesh="wrist_roll_pitch_so101_v2"/>

              <body name="gripper_link" pos="0 -0.0611 0.0181" quat="0.0172 -0.0172 0.7069 0.7069">
                <inertial pos="0 0 -0.025" mass="0.087" diaginertia="4.3e-05 3.5e-05 2.8e-05"/>
                <joint name="wrist_roll" axis="0 0 1" range="-2.74 2.84"/>
                <!-- Gripper visual meshes -->
                <geom pos="0.0077 0.0001 -0.0234" quat="0.707105 -0.707108 0 0" type="mesh" class="robot" rgba="0.1 0.1 0.1 1" mesh="sts3215_03a_v1"/>
                <geom pos="0 -0.000218214 0.000949706" quat="0 -1 0 0" type="mesh" class="robot" rgba="1 0.82 0.12 1" mesh="wrist_roll_follower_so101_v1"/>

                <!-- Jaw visual mesh (revolute, for appearance only) -->
                <body name="jaw_visual" pos="0.0202 0.0188 -0.0234"
                      quat="0.707105 0.707108 0 0">
                  <joint name="jaw_visual_joint" type="hinge" axis="0 0 1"
                         range="-0.175 1.75" damping="0.3"/>
                  <geom pos="0 0 0.0189" type="mesh" rgba="1 0.82 0.12 1"
                        mesh="moving_jaw_so101_v1" contype="0" conaffinity="0"/>
                </body>

                <!-- Gripper geoms (visual reference only, no physics grasping).
                     Actual grasping uses weld constraints (see <equality>). -->
                <geom name="fixed_jaw" type="box" size="0.003 0.012 0.015"
                      pos="-0.012 0 -0.090" rgba="0.75 0.75 0.75 1"
                      contype="0" conaffinity="0" mass="0.003"/>
                <geom name="moving_jaw" type="box" size="0.003 0.012 0.015"
                      pos="0.012 0 -0.090" rgba="0.75 0.75 0.75 1"
                      contype="0" conaffinity="0" mass="0.003"/>

                <!-- End-effector site (finger tip, between the grasp fingers) -->
                <site name="ee_site" pos="0 0 -0.098"
                      size="0.005" rgba="1 0 0 0.5"/>

              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- ============================================================
         Graspable Objects (free bodies on the table surface z=0.02)
         ============================================================ -->
    <!-- Yellow banana — front left -->
    <body name="banana" pos="0.12 0.12 0.06">
      <freejoint name="banana_free"/>
      <geom name="banana_geom" type="mesh" mesh="banana_mesh"
            rgba="1.0 0.9 0.2 1" mass="0.020" condim="4"/>
    </body>

    <!-- Red mug — center front -->
    <body name="mug" pos="0.22 0.05 0.06">
      <freejoint name="mug_free"/>
      <geom name="mug_geom" type="mesh" mesh="mug_mesh"
            rgba="0.85 0.15 0.15 1" mass="0.030" condim="4"/>
    </body>

    <!-- Blue bottle — right front -->
    <body name="bottle" pos="0.30 0.12 0.08">
      <freejoint name="bottle_free"/>
      <geom name="bottle_geom" type="mesh" mesh="bottle_mesh"
            rgba="0.2 0.4 0.9 1" mass="0.025" condim="4"/>
    </body>

    <!-- Green screwdriver — right back -->
    <body name="screwdriver" pos="0.30 -0.10 0.06">
      <freejoint name="screwdriver_free"/>
      <geom name="screwdriver_geom" type="mesh" mesh="screwdriver_mesh"
            rgba="0.1 0.7 0.2 1" mass="0.015" condim="4"/>
    </body>

    <!-- Orange duck — left back -->
    <body name="duck" pos="0.15 -0.10 0.06">
      <freejoint name="duck_free"/>
      <geom name="duck_geom" type="mesh" mesh="duck_mesh"
            rgba="1.0 0.6 0.1 1" mass="0.020" condim="4"/>
    </body>

    <!-- White lego brick — center back -->
    <body name="lego" pos="0.24 -0.08 0.04">
      <freejoint name="lego_free"/>
      <geom name="lego_base" type="box" size="0.016 0.008 0.006"
            rgba="0.95 0.2 0.2 1" mass="0.008" condim="4"/>
      <geom type="cylinder" size="0.003 0.002" pos="-0.008 -0.004 0.008"
            rgba="0.95 0.2 0.2 1" mass="0.0005" condim="4"/>
      <geom type="cylinder" size="0.003 0.002" pos="0.008 -0.004 0.008"
            rgba="0.95 0.2 0.2 1" mass="0.0005" condim="4"/>
      <geom type="cylinder" size="0.003 0.002" pos="-0.008 0.004 0.008"
            rgba="0.95 0.2 0.2 1" mass="0.0005" condim="4"/>
      <geom type="cylinder" size="0.003 0.002" pos="0.008 0.004 0.008"
            rgba="0.95 0.2 0.2 1" mass="0.0005" condim="4"/>
    </body>

  </worldbody>

  <!-- ============================================================
       Weld constraints for grasping (disabled by default).
       Enabled at runtime by MuJoCoGripper.close() when EE is near object.
       ============================================================ -->
  <equality>
    <weld body1="gripper_link" body2="banana" active="false"/>
    <weld body1="gripper_link" body2="mug" active="false"/>
    <weld body1="gripper_link" body2="bottle" active="false"/>
    <weld body1="gripper_link" body2="screwdriver" active="false"/>
    <weld body1="gripper_link" body2="duck" active="false"/>
    <weld body1="gripper_link" body2="lego" active="false"/>
  </equality>

  <!-- ============================================================
       Actuators — position-controlled (mimics STS3215 servos)
       ============================================================ -->
  <actuator>
    <position name="act_shoulder_pan"  joint="shoulder_pan"  kp="100" ctrlrange="-1.92 1.92"/>
    <position name="act_shoulder_lift" joint="shoulder_lift" kp="100" ctrlrange="-1.75 1.75"/>
    <position name="act_elbow_flex"    joint="elbow_flex"    kp="80"  ctrlrange="-1.69 1.69"/>
    <position name="act_wrist_flex"    joint="wrist_flex"    kp="60"  ctrlrange="-1.66 1.66"/>
    <position name="act_wrist_roll"    joint="wrist_roll"    kp="60"  ctrlrange="-2.74 2.84"/>
    <position name="act_jaw_visual"   joint="jaw_visual_joint" kp="20" ctrlrange="-0.175 1.75"/>
  </actuator>

</mujoco>
