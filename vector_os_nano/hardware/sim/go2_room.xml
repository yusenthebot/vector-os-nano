<mujoco model="go2 house">
  <compiler angle="radian" meshdir="GO2_ASSETS_DIR" autolimits="true"/>
  <include file="GO2_MODEL_PATH"/>

  <option cone="elliptic" impratio="100"/>

  <statistic center="10 7 0.5" extent="12"/>

  <visual>
    <headlight diffuse="0.5 0.5 0.5" ambient="0.4 0.4 0.4" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-120" elevation="-25"/>
    <quality shadowsize="4096"/>
  </visual>

  <!--
    HOUSE LAYOUT — 20m x 14m — top-down view

          0      6           14     20
     14  +======+=====+=+====+======+
         |Master| Bath|L|  Guest BR |
         |  BR  | room|a|  (8x4)   |
         |(7x4) |(3x4)|u|          |
     10  +=D====+=D===+D+=====D====+
         |      |                  |
         |Dining|  OPEN HALLWAY    | Study
         |Room  |  + GALLERY       | (6x5)
         |(6x5) |  (8m x 10m)     |
      5  +=D====+  open plan      +=D=====+
         |      |                  |       |
         |Living|  Go2 starts     |Kitchen |
         |Room  |  (10, 3)        |(6x5)  |
         |(6x5) |                  |       |
      0  +======+==================+=======+

    D = doorway (1.2m gap)
    Central hall is ONE open space from y=0..10, x=6..14
  -->

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.88 0.90 0.95" rgb2="0.65 0.70 0.80"
             width="512" height="3072"/>

    <!-- Floor textures -->
    <texture type="2d" name="wood_tex" builtin="checker"
             rgb1="0.82 0.72 0.52" rgb2="0.72 0.62 0.42" width="200" height="200"/>
    <texture type="2d" name="tile_tex" builtin="checker"
             rgb1="0.90 0.90 0.88" rgb2="0.80 0.80 0.78" width="150" height="150"/>
    <texture type="2d" name="carpet_tex" builtin="flat"
             rgb1="0.50 0.52 0.56" rgb2="0.45 0.47 0.51" width="100" height="100"/>
    <texture type="2d" name="marble_tex" builtin="checker"
             rgb1="0.92 0.90 0.85" rgb2="0.85 0.82 0.77" width="120" height="120"/>
    <texture type="2d" name="bath_tex" builtin="checker"
             rgb1="0.85 0.90 0.92" rgb2="0.75 0.80 0.82" width="80" height="80"/>

    <material name="wood_mat" texture="wood_tex" texuniform="true" texrepeat="6 6" reflectance="0.12"/>
    <material name="tile_mat" texture="tile_tex" texuniform="true" texrepeat="8 8" reflectance="0.25"/>
    <material name="carpet_mat" texture="carpet_tex" texuniform="true" texrepeat="3 3" reflectance="0.02"/>
    <material name="marble_mat" texture="marble_tex" texuniform="true" texrepeat="10 12" reflectance="0.2"/>
    <material name="bath_tile" texture="bath_tex" texuniform="true" texrepeat="6 6" reflectance="0.3"/>

    <material name="wall_mat" rgba="0.93 0.93 0.91 1" reflectance="0.04"/>
    <material name="accent_wall" rgba="0.82 0.85 0.90 1" reflectance="0.04"/>

    <!-- Furniture -->
    <material name="dark_wood" rgba="0.35 0.22 0.12 1" reflectance="0.12"/>
    <material name="light_wood" rgba="0.70 0.55 0.38 1" reflectance="0.10"/>
    <material name="oak_mat" rgba="0.60 0.45 0.28 1" reflectance="0.10"/>
    <material name="sofa_blue" rgba="0.25 0.35 0.52 1" reflectance="0.04"/>
    <material name="sofa_grey" rgba="0.55 0.55 0.55 1" reflectance="0.04"/>
    <material name="cushion_mat" rgba="0.75 0.65 0.50 1" reflectance="0.03"/>
    <material name="bed_white" rgba="0.92 0.92 0.90 1" reflectance="0.03"/>
    <material name="bed_blue" rgba="0.30 0.40 0.58 1" reflectance="0.03"/>
    <material name="bed_frame" rgba="0.38 0.28 0.18 1" reflectance="0.08"/>
    <material name="counter_mat" rgba="0.75 0.75 0.72 1" reflectance="0.25"/>
    <material name="steel_mat" rgba="0.82 0.82 0.82 1" reflectance="0.40"/>
    <material name="black_mat" rgba="0.12 0.12 0.12 1" reflectance="0.50"/>
    <material name="shelf_mat" rgba="0.80 0.78 0.72 1" reflectance="0.10"/>
    <material name="ceramic_mat" rgba="0.95 0.93 0.88 1" reflectance="0.20"/>
    <material name="plant_pot" rgba="0.55 0.32 0.22 1" reflectance="0.05"/>
    <material name="plant_leaf" rgba="0.18 0.48 0.18 1" reflectance="0.03"/>
    <material name="rug_red" rgba="0.60 0.15 0.12 1" reflectance="0.02"/>
    <material name="rug_blue" rgba="0.15 0.25 0.45 1" reflectance="0.02"/>
    <material name="rug_beige" rgba="0.82 0.75 0.62 1" reflectance="0.02"/>
    <material name="lamp_shade" rgba="0.95 0.90 0.80 1" reflectance="0.01"/>
    <material name="lamp_base" rgba="0.70 0.65 0.55 1" reflectance="0.15"/>
    <material name="painting_mat" rgba="0.85 0.65 0.40 1" reflectance="0.05"/>
  </asset>

  <worldbody>
    <!-- ==================== LIGHTING ==================== -->
    <!-- Room lights (one per room) -->
    <light name="light_living" pos="3 2.5 2.7" dir="0 0 -1" diffuse="0.55 0.50 0.42" cutoff="65"/>
    <light name="light_dining" pos="3 7.5 2.7" dir="0 0 -1" diffuse="0.55 0.50 0.42" cutoff="65"/>
    <light name="light_kitchen" pos="17 2.5 2.7" dir="0 0 -1" diffuse="0.60 0.58 0.52" cutoff="65"/>
    <light name="light_study" pos="17 7.5 2.7" dir="0 0 -1" diffuse="0.55 0.52 0.45" cutoff="65"/>
    <light name="light_hall_a" pos="10 3 2.7" dir="0 0 -1" diffuse="0.50 0.48 0.42" cutoff="55"/>
    <light name="light_hall_b" pos="10 7 2.7" dir="0 0 -1" diffuse="0.50 0.48 0.42" cutoff="55"/>
    <light name="light_master" pos="3.5 12 2.7" dir="0 0 -1" diffuse="0.50 0.45 0.38" cutoff="60"/>
    <light name="light_guest" pos="16 12 2.7" dir="0 0 -1" diffuse="0.50 0.45 0.38" cutoff="60"/>
    <light name="light_bath" pos="8.5 12 2.7" dir="0 0 -1" diffuse="0.55 0.55 0.55" cutoff="55"/>
    <!-- Global ambient fill -->
    <light name="sun" pos="10 7 4" dir="0 0 -1" directional="true" diffuse="0.25 0.25 0.25"/>

    <!-- ==================== FLOORS ==================== -->
    <!-- Floor: plane for physics contact (correct collision) + box for mj_ray detection -->
    <geom name="floor" type="plane" pos="10 7 0" size="10.5 7.5 0.05" material="marble_mat"/>
    <geom name="floor_raycast" type="box" pos="10 7 -0.02" size="10.5 7.5 0.01"
          contype="0" conaffinity="0" group="3" rgba="0 0 0 0"/>
    <!-- Ceiling: needed for downward-facing lidar rays -->
    <geom name="ceiling" type="box" pos="10 7 2.85" size="10.5 7.5 0.05" material="wall_mat"
          contype="0" conaffinity="0" group="3"/>

    <!-- Per-room floor overlays (visual only) -->
    <geom name="f_living" type="box" pos="3 2.5 0.001" size="3 2.5 0.001" material="wood_mat" contype="0" conaffinity="0"/>
    <geom name="f_dining" type="box" pos="3 7.5 0.001" size="3 2.5 0.001" material="wood_mat" contype="0" conaffinity="0"/>
    <geom name="f_kitchen" type="box" pos="17 2.5 0.001" size="3 2.5 0.001" material="tile_mat" contype="0" conaffinity="0"/>
    <geom name="f_study" type="box" pos="17 7.5 0.001" size="3 2.5 0.001" material="wood_mat" contype="0" conaffinity="0"/>
    <geom name="f_master" type="box" pos="3.5 12 0.001" size="3.5 2 0.001" material="carpet_mat" contype="0" conaffinity="0"/>
    <geom name="f_guest" type="box" pos="16 12 0.001" size="4 2 0.001" material="carpet_mat" contype="0" conaffinity="0"/>
    <geom name="f_bath" type="box" pos="8.5 12 0.001" size="1.5 2 0.001" material="bath_tile" contype="0" conaffinity="0"/>

    <!-- ==================== EXTERIOR WALLS ==================== -->
    <!-- height=2.8m, thickness=0.1m -->
    <geom name="ew_south" type="box" pos="10 -0.05 1.4" size="10.1 0.05 1.4" material="wall_mat"/>
    <geom name="ew_north" type="box" pos="10 14.05 1.4" size="10.1 0.05 1.4" material="wall_mat"/>
    <geom name="ew_west" type="box" pos="-0.05 7 1.4" size="0.05 7.1 1.4" material="wall_mat"/>
    <geom name="ew_east" type="box" pos="20.05 7 1.4" size="0.05 7.1 1.4" material="wall_mat"/>

    <!-- ==================== INTERIOR WALLS ==================== -->

    <!-- LEFT WALL (x=6): Living/Dining ↔ Central Hall -->
    <!-- y=0 to y=2.4 -->
    <geom name="iw_l1" type="box" pos="6 1.2 1.4" size="0.05 1.2 1.4" material="accent_wall"/>
    <!-- y=3.6 to y=5 (gap at 2.4..3.6 = door to Living) -->
    <geom name="iw_l2" type="box" pos="6 4.3 1.4" size="0.05 0.7 1.4" material="accent_wall"/>
    <!-- y=5 to y=7.4 -->
    <geom name="iw_l3" type="box" pos="6 6.2 1.4" size="0.05 1.2 1.4" material="accent_wall"/>
    <!-- y=8.6 to y=10 (gap at 7.4..8.6 = door to Dining) -->
    <geom name="iw_l4" type="box" pos="6 9.3 1.4" size="0.05 0.7 1.4" material="accent_wall"/>

    <!-- RIGHT WALL (x=14): Central Hall ↔ Kitchen/Study -->
    <!-- y=0 to y=2.4 -->
    <geom name="iw_r1" type="box" pos="14 1.2 1.4" size="0.05 1.2 1.4" material="accent_wall"/>
    <!-- y=3.6 to y=5 (gap at 2.4..3.6 = door to Kitchen) -->
    <geom name="iw_r2" type="box" pos="14 4.3 1.4" size="0.05 0.7 1.4" material="accent_wall"/>
    <!-- y=5 to y=7.4 -->
    <geom name="iw_r3" type="box" pos="14 6.2 1.4" size="0.05 1.2 1.4" material="accent_wall"/>
    <!-- y=8.6 to y=10 (gap at 7.4..8.6 = door to Study) -->
    <geom name="iw_r4" type="box" pos="14 9.3 1.4" size="0.05 0.7 1.4" material="accent_wall"/>

    <!-- LIVING/DINING DIVIDER (y=5, x=0..6): door at x=2.4..3.6 -->
    <geom name="iw_ld1" type="box" pos="1.2 5 1.4" size="1.2 0.05 1.4" material="accent_wall"/>
    <geom name="iw_ld2" type="box" pos="4.8 5 1.4" size="1.2 0.05 1.4" material="accent_wall"/>

    <!-- KITCHEN/STUDY DIVIDER (y=5, x=14..20): door at x=16.4..17.6 -->
    <geom name="iw_ks1" type="box" pos="15.2 5 1.4" size="1.2 0.05 1.4" material="accent_wall"/>
    <geom name="iw_ks2" type="box" pos="18.8 5 1.4" size="1.2 0.05 1.4" material="accent_wall"/>

    <!-- BEDROOM WALL (y=10, full width): doors at multiple points -->
    <!-- x=0 to x=2.4 -->
    <geom name="iw_b1" type="box" pos="1.2 10 1.4" size="1.2 0.05 1.4" material="wall_mat"/>
    <!-- x=3.6 to x=6 (gap = door to Master BR) -->
    <geom name="iw_b2" type="box" pos="4.8 10 1.4" size="1.2 0.05 1.4" material="wall_mat"/>
    <!-- x=6 to x=7.9 -->
    <geom name="iw_b3" type="box" pos="6.95 10 1.4" size="0.95 0.05 1.4" material="wall_mat"/>
    <!-- x=9.1 to x=11.4 (gap at 7.9..9.1 = door to Bathroom) -->
    <geom name="iw_b4" type="box" pos="10.25 10 1.4" size="1.15 0.05 1.4" material="wall_mat"/>
    <!-- x=12.0 to x=14 (sealed — old 0.6m gap at x=12..12.6 was too narrow for Go2) -->
    <geom name="iw_b5" type="box" pos="13.0 10 1.4" size="1.0 0.05 1.4" material="wall_mat"/>
    <!-- x=14 to x=15.4 -->
    <geom name="iw_b6" type="box" pos="14.7 10 1.4" size="0.7 0.05 1.4" material="wall_mat"/>
    <!-- x=16.6 to x=20 (gap at 15.4..16.6 = another door to Guest) -->
    <geom name="iw_b7" type="box" pos="18.3 10 1.4" size="1.7 0.05 1.4" material="wall_mat"/>

    <!-- BATHROOM walls (x=7, x=10, y=10..14) -->
    <geom name="iw_bath_w" type="box" pos="7 12 1.4" size="0.05 2.05 1.4" material="wall_mat"/>
    <geom name="iw_bath_e" type="box" pos="10 12 1.4" size="0.05 2.05 1.4" material="wall_mat"/>

    <!-- LAUNDRY nook (x=10..12, y=10..14) — open niche, just east wall -->
    <geom name="iw_laund_e" type="box" pos="12 12 1.4" size="0.05 2.05 1.4" material="wall_mat"/>


    <!-- ==================== LIVING ROOM (x=0..6, y=0..5) ==================== -->

    <!-- L-sofa against south-west -->
    <body name="sofa_main" pos="1.8 1.0 0">
      <geom type="box" pos="0 0 0.18" size="1.2 0.38 0.18" material="sofa_blue"/>
      <geom type="box" pos="0 -0.08 0.42" size="1.15 0.30 0.06" material="sofa_blue"/>
      <geom type="box" pos="0 0.30 0.48" size="1.15 0.06 0.28" material="sofa_blue"/>
      <geom type="box" pos="-1.15 0 0.38" size="0.05 0.38 0.16" material="sofa_blue"/>
      <geom type="box" pos="1.15 0 0.38" size="0.05 0.38 0.16" material="sofa_blue"/>
      <!-- Throw pillows -->
      <geom type="box" pos="-0.7 -0.1 0.52" size="0.15 0.12 0.08" material="cushion_mat"/>
      <geom type="box" pos="0.7 -0.1 0.52" size="0.15 0.12 0.08" material="cushion_mat"/>
    </body>

    <!-- Coffee table -->
    <body name="coffee_tbl" pos="1.8 2.3 0">
      <geom type="cylinder" pos="-0.35 -0.2 0.18" size="0.02 0.18" material="dark_wood"/>
      <geom type="cylinder" pos="0.35 -0.2 0.18" size="0.02 0.18" material="dark_wood"/>
      <geom type="cylinder" pos="-0.35 0.2 0.18" size="0.02 0.18" material="dark_wood"/>
      <geom type="cylinder" pos="0.35 0.2 0.18" size="0.02 0.18" material="dark_wood"/>
      <geom type="box" pos="0 0 0.37" size="0.45 0.25 0.02" material="dark_wood"/>
    </body>

    <!-- TV + media console against west wall -->
    <body name="tv_console" pos="0.25 3.5 0">
      <geom type="box" pos="0 0 0.22" size="0.22 0.8 0.22" material="dark_wood"/>
      <geom type="box" pos="0 0 0.45" size="0.22 0.8 0.01" material="dark_wood"/>
      <geom name="tv" type="box" pos="0.02 0 0.78" size="0.025 0.65 0.4" material="black_mat"/>
    </body>

    <!-- Floor lamp -->
    <body name="lamp_living" pos="0.4 0.5 0">
      <geom type="cylinder" pos="0 0 0.02" size="0.12 0.02" material="lamp_base"/>
      <geom type="cylinder" pos="0 0 0.7" size="0.015 0.68" material="lamp_base"/>
      <geom type="cylinder" pos="0 0 1.38" size="0.12 0.12" material="lamp_shade" contype="0" conaffinity="0"/>
    </body>

    <!-- Rug -->
    <geom name="rug_living" type="box" pos="2.0 2.0 0.004" size="1.5 1.2 0.004"
          material="rug_red" contype="0" conaffinity="0"/>

    <!-- Wall art -->
    <geom name="art_living" type="box" pos="0.02 2.5 1.5" size="0.02 0.4 0.3"
          material="painting_mat" contype="0" conaffinity="0"/>


    <!-- ==================== DINING ROOM (x=0..6, y=5..10) ==================== -->

    <!-- Dining table (large, 8-seater) -->
    <body name="dining_table" pos="3 7.5 0">
      <geom type="cylinder" pos="-0.65 -0.4 0.36" size="0.035 0.36" material="oak_mat"/>
      <geom type="cylinder" pos="0.65 -0.4 0.36" size="0.035 0.36" material="oak_mat"/>
      <geom type="cylinder" pos="-0.65 0.4 0.36" size="0.035 0.36" material="oak_mat"/>
      <geom type="cylinder" pos="0.65 0.4 0.36" size="0.035 0.36" material="oak_mat"/>
      <geom type="box" pos="0 0 0.73" size="0.8 0.5 0.025" material="oak_mat"/>
    </body>

    <!-- 4 dining chairs -->
    <body name="dchair1" pos="2.0 7.5 0">
      <geom type="box" pos="0 0 0.23" size="0.17 0.17 0.23" material="light_wood" contype="0" conaffinity="0"/>
      <geom type="box" pos="0 0 0.46" size="0.19 0.19 0.015" material="light_wood"/>
      <geom type="box" pos="0 0.17 0.66" size="0.17 0.015 0.19" material="light_wood"/>
    </body>
    <body name="dchair2" pos="4.0 7.5 0">
      <geom type="box" pos="0 0 0.23" size="0.17 0.17 0.23" material="light_wood" contype="0" conaffinity="0"/>
      <geom type="box" pos="0 0 0.46" size="0.19 0.19 0.015" material="light_wood"/>
      <geom type="box" pos="0 -0.17 0.66" size="0.17 0.015 0.19" material="light_wood"/>
    </body>
    <body name="dchair3" pos="3.0 6.7 0">
      <geom type="box" pos="0 0 0.23" size="0.17 0.17 0.23" material="light_wood" contype="0" conaffinity="0"/>
      <geom type="box" pos="0 0 0.46" size="0.19 0.19 0.015" material="light_wood"/>
      <geom type="box" pos="0 0.17 0.66" size="0.17 0.015 0.19" material="light_wood"/>
    </body>
    <body name="dchair4" pos="3.0 8.3 0">
      <geom type="box" pos="0 0 0.23" size="0.17 0.17 0.23" material="light_wood" contype="0" conaffinity="0"/>
      <geom type="box" pos="0 0 0.46" size="0.19 0.19 0.015" material="light_wood"/>
      <geom type="box" pos="0 -0.17 0.66" size="0.17 0.015 0.19" material="light_wood"/>
    </body>

    <!-- Sideboard / buffet against west wall -->
    <body name="sideboard" pos="0.3 8.5 0">
      <geom type="box" pos="0 0 0.4" size="0.25 0.7 0.4" material="oak_mat"/>
      <geom type="box" pos="0 0 0.81" size="0.25 0.7 0.01" material="oak_mat"/>
    </body>

    <!-- Plant in dining corner -->
    <body name="plant_dining" pos="0.5 5.5 0">
      <geom type="cylinder" pos="0 0 0.22" size="0.15 0.22" material="plant_pot"/>
      <geom type="sphere" pos="0 0 0.58" size="0.28" material="plant_leaf" contype="0" conaffinity="0"/>
    </body>


    <!-- ==================== KITCHEN (x=14..20, y=0..5) ==================== -->

    <!-- L-shaped counter (along east + south walls) -->
    <body name="counter_east" pos="19.6 2.5 0">
      <geom type="box" pos="0 0 0.44" size="0.35 2.3 0.44" material="counter_mat"/>
      <geom type="box" pos="0 0 0.90" size="0.38 2.3 0.015" material="counter_mat"/>
    </body>
    <body name="counter_south" pos="17 0.4 0">
      <geom type="box" pos="0 0 0.44" size="2.8 0.35 0.44" material="counter_mat"/>
      <geom type="box" pos="0 0 0.90" size="2.8 0.38 0.015" material="counter_mat"/>
    </body>

    <!-- Kitchen island -->
    <body name="island" pos="17 2.8 0">
      <geom type="box" pos="0 0 0.44" size="0.8 0.4 0.44" material="counter_mat"/>
      <geom type="box" pos="0 0 0.90" size="0.85 0.45 0.015" material="counter_mat"/>
    </body>

    <!-- Fridge (tall, against east wall near north) -->
    <body name="fridge" pos="19.5 4.3 0">
      <geom type="box" pos="0 0 0.9" size="0.38 0.38 0.9" material="steel_mat"/>
    </body>

    <!-- Bar stools at island -->
    <body name="stool1" pos="16.0 2.8 0">
      <geom type="cylinder" pos="0 0 0.35" size="0.16 0.35" material="dark_wood"/>
      <geom type="cylinder" pos="0 0 0.73" size="0.17 0.03" material="sofa_grey"/>
    </body>
    <body name="stool2" pos="18.0 2.8 0">
      <geom type="cylinder" pos="0 0 0.35" size="0.16 0.35" material="dark_wood"/>
      <geom type="cylinder" pos="0 0 0.73" size="0.17 0.03" material="sofa_grey"/>
    </body>


    <!-- ==================== STUDY (x=14..20, y=5..10) ==================== -->

    <!-- L-desk against east wall -->
    <body name="desk" pos="19.2 7.5 0">
      <geom type="box" pos="0 0 0.36" size="0.05 0.3 0.36" material="dark_wood"/>
      <geom type="box" pos="-0.6 0 0.36" size="0.05 0.3 0.36" material="dark_wood"/>
      <geom type="box" pos="-0.3 0 0.73" size="0.4 0.35 0.02" material="dark_wood"/>
      <!-- Monitor -->
      <geom type="box" pos="-0.3 0.18 0.95" size="0.28 0.02 0.20" material="black_mat"/>
      <geom type="box" pos="-0.3 0.12 0.78" size="0.06 0.06 0.04" material="black_mat"/>
      <!-- Keyboard -->
      <geom type="box" pos="-0.3 -0.05 0.76" size="0.18 0.06 0.01" material="black_mat"
            contype="0" conaffinity="0"/>
    </body>

    <!-- Desk chair (on wheels) -->
    <body name="desk_chair" pos="18.3 7.5 0">
      <geom type="cylinder" pos="0 0 0.22" size="0.25 0.02" material="black_mat"/>
      <geom type="cylinder" pos="0 0 0.35" size="0.04 0.12" material="black_mat"/>
      <geom type="box" pos="0 0 0.50" size="0.22 0.22 0.03" material="sofa_grey"/>
      <geom type="box" pos="0 0.20 0.72" size="0.20 0.03 0.20" material="sofa_grey"/>
    </body>

    <!-- Large bookshelf (against south wall of study) -->
    <body name="bookshelf" pos="17 5.3 0">
      <geom type="box" pos="0 0 1.0" size="1.2 0.18 1.0" material="shelf_mat"/>
      <geom type="box" pos="0 0 0.45" size="1.18 0.16 0.01" material="shelf_mat"/>
      <geom type="box" pos="0 0 0.90" size="1.18 0.16 0.01" material="shelf_mat"/>
      <geom type="box" pos="0 0 1.35" size="1.18 0.16 0.01" material="shelf_mat"/>
      <geom type="box" pos="0 0 1.80" size="1.18 0.16 0.01" material="shelf_mat"/>
    </body>

    <!-- Study rug -->
    <geom name="rug_study" type="box" pos="17.5 7.5 0.004" size="1.8 1.5 0.004"
