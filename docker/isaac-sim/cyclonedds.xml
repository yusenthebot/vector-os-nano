<?xml version="1.0" encoding="UTF-8"?>
<!--
  CycloneDDS config for Isaac Sim bridge (ROS2 Jazzy compatible).
  SharedMemory disabled — container and host have separate SHM namespaces.
-->
<CycloneDDS>
  <Domain id="0">
    <General>
      <AllowMulticast>true</AllowMulticast>
    </General>
    <SharedMemory>
      <Enable>false</Enable>
    </SharedMemory>
    <Internal>
      <SocketReceiveBufferSize min="1MB"/>
    </Internal>
    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>50</MaxAutoParticipantIndex>
    </Discovery>
    <Tracing>
      <Verbosity>warning</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>
  </Domain>
</CycloneDDS>
