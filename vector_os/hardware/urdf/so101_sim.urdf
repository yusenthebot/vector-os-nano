<?xml version="1.0" encoding="utf-8"?>
<!-- Simplified SO-101 URDF for PyBullet simulation.
     Uses primitive collision/visual shapes only — no mesh files required.
     Kinematic parameters (joint origins, axes, limits) match so101.urdf exactly.
     Inertia parameters are simplified approximations for simulation.
-->
<robot name="so101_sim">

  <!-- base_link: fixed to world -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.014 0 0.033" rpy="0 0 0"/>
      <mass value="0.147"/>
      <inertia ixx="0.000115" ixy="0" ixz="0" iyy="0.000136" iyz="0" izz="0.000130"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 0.07"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry><box size="0.06 0.06 0.07"/></geometry>
    </collision>
  </link>

  <!-- shoulder_link -->
  <link name="shoulder_link">
    <inertial>
      <origin xyz="-0.031 0 -0.025" rpy="0 0 0"/>
      <mass value="0.100"/>
      <inertia ixx="8.4e-05" ixy="0" ixz="0" iyy="8.1e-05" iyz="0" izz="2.4e-05"/>
    </inertial>
    <visual>
      <origin xyz="-0.030 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.015" length="0.06"/></geometry>
    </visual>
    <collision>
      <origin xyz="-0.030 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.015" length="0.06"/></geometry>
    </collision>
  </link>

  <!-- Joint from base to shoulder (shoulder_pan) -->
  <joint name="shoulder_pan" type="revolute">
    <origin xyz="0.0388 0 0.0624" rpy="3.14159 0 -3.14159"/>
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.91986" upper="1.91986"/>
  </joint>

  <!-- upper_arm_link -->
  <link name="upper_arm_link">
    <inertial>
      <origin xyz="-0.090 -0.008 0.018" rpy="0 0 0"/>
      <mass value="0.103"/>
      <inertia ixx="4.1e-05" ixy="0" ixz="0" iyy="0.000147" iyz="0" izz="0.000142"/>
    </inertial>
    <visual>
      <origin xyz="-0.055 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.014" length="0.11"/></geometry>
    </visual>
    <collision>
      <origin xyz="-0.055 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.014" length="0.11"/></geometry>
    </collision>
  </link>

  <!-- Joint from shoulder to upper_arm (shoulder_lift) -->
  <joint name="shoulder_lift" type="revolute">
    <origin xyz="-0.0304 -0.0183 -0.0542" rpy="-1.5708 -1.5708 0"/>
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.74533" upper="1.74533"/>
  </joint>

  <!-- lower_arm_link -->
  <link name="lower_arm_link">
    <inertial>
      <origin xyz="-0.098 0.003 0.018" rpy="0 0 0"/>
      <mass value="0.104"/>
      <inertia ixx="2.9e-05" ixy="0" ixz="0" iyy="0.000160" iyz="0" izz="0.000145"/>
    </inertial>
    <visual>
      <origin xyz="-0.065 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.013" length="0.13"/></geometry>
    </visual>
    <collision>
      <origin xyz="-0.065 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.013" length="0.13"/></geometry>
    </collision>
  </link>

  <!-- Joint from upper_arm to lower_arm (elbow_flex) -->
  <joint name="elbow_flex" type="revolute">
    <origin xyz="-0.11257 -0.028 0" rpy="0 0 1.5708"/>
    <parent link="upper_arm_link"/>
    <child link="lower_arm_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.69" upper="1.69"/>
  </joint>

  <!-- wrist_link -->
  <link name="wrist_link">
    <inertial>
      <origin xyz="0 -0.039 0.028" rpy="0 0 0"/>
      <mass value="0.079"/>
      <inertia ixx="3.7e-05" ixy="0" ixz="0" iyy="2.5e-05" iyz="0" izz="2.1e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.03 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.012" length="0.06"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 -0.03 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.012" length="0.06"/></geometry>
    </collision>
  </link>

  <!-- Joint from lower_arm to wrist (wrist_flex) -->
  <joint name="wrist_flex" type="revolute">
    <origin xyz="-0.1349 0.0052 0" rpy="0 0 -1.5708"/>
    <parent link="lower_arm_link"/>
    <child link="wrist_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-1.65806" upper="1.65806"/>
  </joint>

  <!-- gripper_link -->
  <link name="gripper_link">
    <inertial>
      <origin xyz="0 0 -0.025" rpy="0 0 0"/>
      <mass value="0.087"/>
      <inertia ixx="2.8e-05" ixy="0" ixz="0" iyy="4.3e-05" iyz="0" izz="3.5e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.06"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.06"/></geometry>
    </collision>
  </link>

  <!-- Joint from wrist to gripper (wrist_roll) -->
  <joint name="wrist_roll" type="revolute">
    <origin xyz="0 -0.0611 0.0181" rpy="1.5708 0.0487 3.14159"/>
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-2.74385" upper="2.84121"/>
  </joint>

  <!-- moving_jaw_link (gripper finger) -->
  <link name="moving_jaw_link">
    <inertial>
      <origin xyz="-0.002 -0.030 0.019" rpy="0 0 0"/>
      <mass value="0.012"/>
      <inertia ixx="6.6e-06" ixy="0" ixz="0" iyy="1.9e-06" iyz="0" izz="5.3e-06"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.02 0" rpy="1.5708 0 0"/>
      <geometry><box size="0.015 0.04 0.012"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 -0.02 0" rpy="1.5708 0 0"/>
      <geometry><box size="0.015 0.04 0.012"/></geometry>
    </collision>
  </link>

  <!-- Joint: gripper rotation -->
  <joint name="gripper" type="revolute">
    <origin xyz="0.0202 0.0188 -0.0234" rpy="1.5708 0 0"/>
    <parent link="gripper_link"/>
    <child link="moving_jaw_link"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" velocity="10" lower="-0.174533" upper="1.74533"/>
  </joint>

  <!-- gripper_frame_link (end-effector tip reference) -->
  <link name="gripper_frame_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1e-9"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
  </link>

  <joint name="gripper_frame_joint" type="fixed">
    <origin xyz="-0.0079 -0.000218 -0.0981" rpy="0 3.14159 0"/>
    <parent link="gripper_link"/>
    <child link="gripper_frame_link"/>
    <axis xyz="0 0 0"/>
  </joint>

</robot>
